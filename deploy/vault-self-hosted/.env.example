# Public origins. Production values must use HTTPS and must not contain paths,
# credentials, query strings, fragments, or wildcards.
APP_ORIGIN=https://vault.example.com
SUPABASE_PUBLIC_URL=https://supabase.example.com

# Internal server-to-server Supabase URL. It may be the same HTTPS URL as the
# public endpoint, or an internal Docker DNS URL when the official Supabase
# self-hosted stack shares a network with this deployment.
VAULT_SUPABASE_URL=https://supabase.example.com

# The anon key is intentionally public and is embedded in the App build.
SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# PostgreSQL connection used only by one-shot migration/backup/restore jobs.
# Keep this file out of source control and restrict filesystem permissions.
VAULT_DATABASE_URL=postgresql://postgres:replace-password@database.example.com:5432/postgres?sslmode=require

# A full Supabase database restore must run as the owner/superuser of the
# platform event triggers. Official self-hosted Supabase uses supabase_admin.
# Hosted/remote recovery targets may require a different operator-provided role.
VAULT_DATABASE_RESTORE_ROLE=supabase_admin

# Use a random value of at least 32 characters. The same value is configured
# as VAULT_ROOM_CONTROL_PLANE_TOKEN in the vault-control-plane Edge Function.
VAULT_CONTROL_PLANE_TOKEN=replace-with-at-least-32-random-characters

# Vault remains disabled unless explicitly enabled in the production build.
VAULT_ENABLED=false

# Bounded server-visible metadata/resource limits. They do not inspect or
# derive plaintext content.
VAULT_MAX_PAYLOAD_BYTES=1048576
VAULT_MAX_MESSAGES_PER_MINUTE=1200
VAULT_MAX_CONNECTIONS_PER_VAULT=64
VAULT_CAPABILITY_RESOLVE_TIMEOUT_MS=5000
VAULT_ALLOW_DOCKER_HOST_HTTP=false

# Compose/build locations and published ports.
ROOM_SERVER_CONTEXT=../../../excalidraw-room
HTTP_PORT=80
HTTPS_PORT=443

# Optional ACME contact used by Caddy.
ACME_EMAIL=admin@example.com
