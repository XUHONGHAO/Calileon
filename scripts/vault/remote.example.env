# Copy to remote.local.env. That filename is ignored by Git.
# Use a disposable, isolated hosted Supabase project only.
VAULT_SUPABASE_PROJECT_REF=replace_with_20_char_project_ref
VAULT_REMOTE_CONFIRM_PROJECT_REF=replace_with_the_same_project_ref
VAULT_REMOTE_CONFIRM_DISPOSABLE=DISPOSABLE_TEST_PROJECT

# URL-encode reserved characters in the password. The project ref must also be
# visible in the URI (direct host or pooler username), otherwise the script
# refuses the target.
VAULT_SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@POOLER_HOST:5432/postgres?sslmode=verify-full&sslrootcert=system
# Download the project's public CA certificate from Supabase Connect.
VAULT_SUPABASE_SSLROOTCERT_PATH=C:\path\to\supabase-ca.crt

# Supabase CLI reads this directly. Never commit the real token.
SUPABASE_ACCESS_TOKEN=replace_with_personal_access_token

# F3 browser discovery and immediate revoke fan-out. Configure all three
# together. The room URL must be public HTTPS for a hosted Edge Function.
VAULT_APP_ALLOWED_ORIGINS=https://vault-app.example
VAULT_ROOM_CONTROL_PLANE_URL=https://room.example/vault/control-plane/disconnect
VAULT_ROOM_CONTROL_PLANE_TOKEN=replace_with_at_least_32_random_characters
